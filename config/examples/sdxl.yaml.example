id: sdxl
display_name: "Stable Diffusion XL"
category: image
provider_class: DiffusersImageProvider
enabled: true

model:
  hub_id: "stabilityai/stable-diffusion-xl-base-1.0"
  vram_mb: 7000
  torch_dtype: float16
  default_params:
    num_inference_steps: 30
    guidance_scale: 7.5
    width: 1024
    height: 1024

cache:
  enabled: true
  strategy: seed_only
  ttl_hours: null
  max_size_mb: 2048

queue:
  priority: low
  timeout_seconds: 120
  max_concurrent: 1

metadata:
  license: "Stability AI Community"
  description: "Stable Diffusion XL base model"
  tags: ["sdxl", "stable-diffusion"]
